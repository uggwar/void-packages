# Template file for 'hip-runtime-amd'
pkgname=hip-runtime-amd
version=6.1.1
revision=2
hostmakedepends="tar perl wget cmake python3 python3-cppheaderparser ninja pkg-config rocm-llvm"
makedepends="rocm-common numactl libnuma-devel MesaLib-devel comgr rocminfo libxml2-devel libedit-devel zlib-devel ncurses-libtinfo-devel libzstd-devel"
depends=""
short_desc="Heterogeneous Interface for Portability ROCm"
maintainer="Christer Stenbrenden <christer@uggwar.net>"
license="MIT"
homepage="https://rocm.docs.amd.com/projects/HIP/en/latest/"

do_fetch() {
	mkdir -p ${wrksrc}
	wget https://github.com/ROCm/HIP/archive/rocm-${version}.tar.gz -O ${wrksrc}/rocm-${version}.tar.gz
	wget https://github.com/ROCm/clr/archive/rocm-${version}.tar.gz -O ${wrksrc}/rocm-clr-${version}.tar.gz
	wget https://github.com/ROCm/llvm-project/archive/refs/tags/rocm-${version}.tar.gz -O ${wrksrc}/rocm-hipcc-${version}.tar.gz
}

do_extract() {
	tar xf ${wrksrc}/rocm-${version}.tar.gz
	tar xf ${wrksrc}/rocm-clr-${version}.tar.gz
	tar xf ${wrksrc}/rocm-hipcc-${version}.tar.gz
}

do_build() {
	CXXFLAGS=${CXXFLAGS/-Wp,-D_GLIBCXX_ASSERTIONS/}
	CXXFLAGS+=" -DNDEBUG"
	CFLAGS+=" -DNDEBUG"

	cmake -Wno-dev -S "${wrksrc}/llvm-project-rocm-${version}/amd/hipcc" -B build-hipcc -DCMAKE_BUILD_TYPE=None
	cmake --build build-hipcc

	cmake -Wno-dev -S "${wrksrc}/clr-rocm-${version}" -B build -DCMAKE_BUILD_TYPE=None -DCMAKE_INSTALL_PREFIX=/opt/rocm/ -DHIP_COMMON_DIR="${wrksrc}/HIP-rocm-${version}" -DHIPCC_BIN_DIR="${wrksrc}/build-hipcc" -DHIP_CATCH_TEST=0 -DCLR_BUILD_HIP=ON -DCLR_BUILD_OCL=OFF -DCMAKE_PREFIX_PATH=/opt/rocm/lib/llvm
	cmake --build build
}

do_install() {
	DESTDIR=${DESTDIR} cmake --install build
	# Remove Windows scripts
	echo '/opt/rocm/hip/lib' > "$pkgname.conf"
	vinstall "${pkgname}.conf" 644 etc/ld.so.conf.d
}
